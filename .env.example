# PostgreSQL connection (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/phalerae?schema=public"

# OpenAI — improves phrasing, refusals, and NLU. If omitted, heuristic parsing is used (less reliable).
OPENAI_API_KEY=""
# Optional override (default: gpt-4o-mini)
OPENAI_MODEL="gpt-4o-mini"

# Admin dashboard — HS256 secret for httpOnly cookie session (min 16 characters)
ADMIN_JWT_SECRET="replace-with-long-random-string"

# Resend — new lead email alerts (optional for local dev)
RESEND_API_KEY=""
# Must be a verified sender in Resend, e.g. "Phalerae <onboarding@resend.dev>"
RESEND_FROM_EMAIL=""

# Where to send alerts if Firm.notificationEmail is empty
LEAD_ALERT_EMAIL="intake@yourfirm.com"

# Intake API: max requests per IP per rolling minute (default 30)
INTAKE_RATE_LIMIT_PER_MIN="30"

# prisma/seed.ts — password for admin@phalerae.local (default: changeme)
SEED_ADMIN_PASSWORD="changeme"
